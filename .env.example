# API base URL (no trailing slash). Used by /api/proxy to forward requests.
# Production: https://chaadenergy.vercel.app/api
# Local: copy to .env.local and override if needed (e.g. same URL or a different backend).
NEXT_PUBLIC_API_BASE_URL=https://chaadenergy.vercel.app/api

# Canonical base URL for SEO and Open Graph (e.g. https://chaadenergy.com)
NEXT_PUBLIC_SITE_URL=

# Optional: Twitter handle for cards (e.g. @chaadenergy)
NEXT_PUBLIC_TWITTER_HANDLE=
